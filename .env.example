# Server
PORT=3000
BRIDGE_BASE_URL=https://your-bridge.up.railway.app
API_KEY=oneshot-dev

# Mentra Client (for bun run dev:client)
PACKAGE_NAME=your-mentra-package-name
MENTRAOS_API_KEY=your-mentra-api-key
GEMINI_API_KEY=your-gemini-api-key
# BRIDGE_API_KEY=           # optional — set to enable real QR→bridge resolution

# Auki Network (bridge's own credentials — used to read/write the domain)
AUKI_EMAIL=
AUKI_PASSWORD=
AUKI_DOMAIN_ID=
AUKI_API_BASE_URL=https://api.auki.network
AUKI_DDS_BASE_URL=https://dds.auki.network
