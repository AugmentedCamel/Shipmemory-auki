# ShipMemory Bridge
#
# Everything here is OPTIONAL. On first boot the bridge shows a setup wizard
# at /ui that collects Auki credentials + an API key and persists them to
# data/config.json. Use env vars only when you want to pin values on a
# managed host (Railway, Fly, Docker) — env vars always win over the UI.

# Server
PORT=3000
BRIDGE_BASE_URL=https://your-bridge.up.railway.app   # Public URL baked into generated QR codes

# --- Optional overrides (skip the setup wizard) ---
# API_KEY=your-api-key                 # Bridge's client-facing API key (BRIDGE_API_KEY in client apps)
# AUKI_EMAIL=you@example.com
# AUKI_PASSWORD=your-password
# AUKI_DOMAIN_ID=your-domain-id

# --- Auki network endpoints (rarely changed) ---
# AUKI_API_BASE_URL=https://api.auki.network
# AUKI_DDS_BASE_URL=https://dds.auki.network

# ----------------------------------------------------------------------
# Mentra Client (for bun run dev:client) — separate process, same .env OK
# ----------------------------------------------------------------------
# PACKAGE_NAME=your-mentra-package-name
# MENTRAOS_API_KEY=your-mentra-api-key
# GEMINI_API_KEY=your-gemini-api-key
# BRIDGE_API_KEY=                      # Same value as bridge's API_KEY
# CONTEXT_CARD_URL=                    # Optional — skip QR, fetch this card directly
