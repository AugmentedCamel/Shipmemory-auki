    "start:client": "bun src/client/index.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@mentra/sdk": "^2.0.3",
    "axios": "^1.7.0",
    "base45-js": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsqr": "^1.4.0",
    "pako": "^2.1.0",
    "qrcode": "^1.5.4",
    "werift": "^0.19.0",
    "ws": "^8.18.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/pako": "^2.0.4",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.18.0",
    "typescript": "^5.6.0"
  }
