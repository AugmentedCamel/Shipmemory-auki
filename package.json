{
  "name": "shipmemory-bridge",
  "version": "0.1.0",
  "description": "Open-source API bridge that resolves QR lookup keys to ContextCards on Auki Domains",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "dev:client": "bun --hot src/client/index.ts",
